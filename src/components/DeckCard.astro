---
import type { Deck, LangCode } from '../lib/decks';
import { monthLabel } from '../lib/decks';

interface Props {
  deck: Deck;
  lang?: LangCode;
}

const { deck, lang = 'en' } = Astro.props;
const month = monthLabel(deck.date, lang);
const dateLabel =
  deck.date && month ? `${month} ${deck.date.slice(0, 4)}` : deck.date;
---

<article class={`deck${deck.available ? '' : ' deck--missing'}`}>
  <a class="deck__thumb" href={deck.primaryUrl ?? '#'} target="_blank" rel="noopener">
    {deck.primaryThumbnail ? (
      <img src={deck.primaryThumbnail} alt="" loading="lazy" />
    ) : (
      <span class="deck__thumb-fallback">{deck.title.slice(0, 1)}</span>
    )}
  </a>

  <div class="deck__body">
    {dateLabel && <p class="deck__date">{dateLabel}</p>}
    <h3 class="deck__title">
      {deck.primaryUrl ? (
        <a href={deck.primaryUrl} target="_blank" rel="noopener">{deck.title}</a>
      ) : (
        <span>{deck.title}</span>
      )}
    </h3>
    {deck.subtitle && <p class="deck__subtitle">{deck.subtitle}</p>}
    {deck.summary && <p class="deck__summary">{deck.summary}</p>}

    <div class="deck__meta">
      {deck.tags && deck.tags.length > 0 && (
        <span class="deck__tags">
          {deck.tags.map((tag, i) => (
            <>
              {i > 0 && ', '}
              <span>{tag}</span>
            </>
          ))}
        </span>
      )}
      <span class="deck__langs">
        {deck.languages.map((l, i) => (
          <>
            {i > 0 && <span class="deck__sep">·</span>}
            <span class="deck__lang">
              <span class="deck__lang-label">{l.lang.toUpperCase()}</span>
              {l.html ? (
                <a href={l.html} target="_blank" rel="noopener">html</a>
              ) : (
                <span class="deck__muted">html</span>
              )}
              {l.pdf && (
                <>
                  <span class="deck__dot">·</span>
                  <a href={l.pdf} target="_blank" rel="noopener">pdf</a>
                </>
              )}
            </span>
          </>
        ))}
      </span>
    </div>
  </div>
</article>

<style>
  .deck {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 24px;
    padding: 26px 0;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .deck:last-child {
    border-bottom: none;
  }

  .deck--missing {
    opacity: 0.55;
  }

  .deck__thumb {
    display: block;
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .deck__thumb:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 14px -8px rgba(0, 0, 0, 0.3);
  }

  .deck__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .deck__thumb-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--kb-font-serif);
    font-size: 40px;
    color: var(--sl-color-gray-3);
  }

  .deck__date {
    font-size: 12px;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 8px;
  }

  .deck__title {
    font-family: var(--kb-font-serif);
    font-weight: 500;
    font-size: 24px;
    line-height: 1.15;
    margin: 0 0 6px;
    letter-spacing: -0.01em;
  }

  .deck__title a,
  .deck__title span {
    color: var(--sl-color-white);
    text-decoration: none;
  }

  .deck__title a:hover {
    color: var(--sl-color-accent);
  }

  .deck__subtitle {
    font-family: var(--kb-font-serif);
    font-style: italic;
    font-size: 16px;
    color: var(--sl-color-gray-3);
    margin: 0 0 12px;
  }

  .deck__summary {
    color: var(--sl-color-gray-2);
    margin: 8px 0 14px;
    font-size: 15px;
    line-height: 1.6;
  }

  .deck__meta {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 13px;
    color: var(--sl-color-gray-3);
  }

  .deck__tags span {
    font-family: var(--sl-font-mono);
    font-size: 12px;
  }

  .deck__langs {
    margin-left: auto;
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }

  .deck__lang {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }

  .deck__lang-label {
    font-family: var(--sl-font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--sl-color-white);
    background: var(--sl-color-accent-low);
    padding: 1px 6px;
    border-radius: 3px;
  }

  .deck__lang a {
    color: var(--sl-color-gray-3);
  }

  .deck__lang a:hover {
    color: var(--sl-color-accent);
  }

  .deck__muted {
    color: var(--sl-color-gray-4);
    text-decoration: line-through;
  }

  .deck__sep,
  .deck__dot {
    color: var(--sl-color-gray-4);
  }

  @media (max-width: 640px) {
    .deck {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
