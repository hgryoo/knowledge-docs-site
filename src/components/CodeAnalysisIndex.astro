---
import { getCollection } from 'astro:content';

// Mirrors knowledge-base-site's generate_index.py:
// reads frontmatter from every code-analysis/<project>/*.md, groups by
// `subcategory:`, and emits a jumplist + per-subcategory bullet list.
// Parameterized by project (cubrid | postgres) and locale (en | ko) so the
// same component renders each project section on both language indexes.

interface Props {
  project: string;
  locale?: 'en' | 'ko';
}

const { project, locale = 'en' } = Astro.props;

// Subcategory display order + labels — the UNION across projects, kept
// identical to CODE_ANALYSIS_SUBCATS in knowledge-base-site's
// generate_index.py. A project simply omits the buckets it does not use;
// docs whose `subcategory:` is not listed fall through to "Other".
const ORDER: Array<[string, string]> = [
  ['overview',            'Overview & Reading Paths'],
  ['base-infra',          'Base / Infrastructure'],
  ['storage-engine',      'Storage Engine'],
  ['txn-recovery',        'Transaction & Recovery'],
  ['query-processing',    'Query Processing'],
  ['ddl-schema',          'DDL & Schema'],
  ['replication-ha',      'Replication & HA'],
  ['server-architecture', 'Server Architecture'],
  ['system-catalog',      'System Catalog'],
  ['monitoring-stats',    'Monitoring & Statistics'],
  ['client-protocol',     'Client Protocol'],
  ['extensibility',       'Extensibility'],
  ['pl-language',         'Procedural Language'],
  ['i18n-text',           'Internationalization & Text'],
  ['i18n-specialty',      'Internationalization & Specialty'],
  ['utilities',           'Utilities'],
  ['evolution',           'Version Evolution'],
];

const all = await getCollection('docs');
const localePrefix = locale === 'ko' ? 'ko/' : '';
const prefix = `${localePrefix}code-analysis/${project}/`;

type Entry = {
  slug: string;
  title: string;
  summary?: string;
  subcategory?: string;
};

const entries: Entry[] = [];
for (const e of all) {
  if (!e.id.startsWith(prefix)) continue;
  const slug = e.id.slice(prefix.length);
  if (!slug || slug.includes('/')) continue;
  entries.push({
    slug,
    title: (e.data as any).title ?? slug,
    summary: (e.data as any).summary,
    subcategory: (e.data as any).subcategory,
  });
}
entries.sort((a, b) => a.slug.localeCompare(b.slug));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = (slug: string) =>
  `${base}/${localePrefix}code-analysis/${project}/${slug}/`;

const buckets = new Map<string, Entry[]>();
const validSlugs = new Set(ORDER.map(([s]) => s));
const untagged: Entry[] = [];
for (const e of entries) {
  if (e.subcategory && validSlugs.has(e.subcategory)) {
    if (!buckets.has(e.subcategory)) buckets.set(e.subcategory, []);
    buckets.get(e.subcategory)!.push(e);
  } else {
    untagged.push(e);
  }
}

function slugify(label: string): string {
  return label
    .toLowerCase()
    .replace(/[&/()]/g, '')
    .trim()
    .replace(/\s+/g, '-');
}

// Anchor ids are prefixed with the project so two instances of this
// component can coexist on the same index page without collisions.
const anchor = (heading: string) => `${project}-${slugify(heading)}`;

const jumpLabel = locale === 'ko' ? '바로가기:' : 'Jump to:';

const chips: Array<{ label: string; href: string }> = [];
for (const [slug, label] of ORDER) {
  const bucket = buckets.get(slug);
  if (!bucket || bucket.length === 0) continue;
  chips.push({
    label,
    href: `#${anchor(`${label} (${bucket.length})`)}`,
  });
}
---

<p class="ca-jump">
  <strong>{jumpLabel}</strong>{' '}
  {chips.map((c, i) => (
    <>
      {i > 0 && ' · '}
      <a href={c.href}>{c.label}</a>
    </>
  ))}
</p>

{ORDER.map(([slug, label]) => {
  const bucket = buckets.get(slug);
  if (!bucket || bucket.length === 0) return null;
  const heading = `${label} (${bucket.length})`;
  return (
    <section class="ca-section">
      <h3 id={anchor(heading)}>{heading}</h3>
      <ul class="ca-list">
        {bucket.map((e) => (
          <li>
            <a href={href(e.slug)}>{e.title}</a>
            {e.summary && (
              <>
                {' — '}
                <span class="ca-summary">{e.summary}</span>
              </>
            )}
          </li>
        ))}
      </ul>
    </section>
  );
})}

{untagged.length > 0 && (
  <section class="ca-section">
    <h3 id={anchor(`Other (${untagged.length})`)}>Other ({untagged.length})</h3>
    <ul class="ca-list">
      {untagged.map((e) => (
        <li>
          <a href={href(e.slug)}>{e.title}</a>
          {e.summary && (
            <>
              {' — '}
              <span class="ca-summary">{e.summary}</span>
            </>
          )}
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .ca-jump {
    border-top: 1px solid var(--sl-color-gray-5);
    border-bottom: 1px solid var(--sl-color-gray-5);
    padding: 14px 0;
    margin: 28px 0;
    font-size: 14px;
    line-height: 1.7;
    color: var(--sl-color-gray-2);
  }

  .ca-jump strong {
    color: var(--sl-color-white);
    margin-right: 4px;
  }

  .ca-jump a {
    color: var(--sl-color-gray-2);
    text-decoration: underline;
    text-decoration-color: var(--sl-color-gray-4);
    text-underline-offset: 2px;
  }

  .ca-jump a:hover {
    color: var(--sl-color-accent);
    text-decoration-color: var(--sl-color-accent);
  }

  .ca-section {
    margin-top: 36px;
  }

  .ca-section h3 {
    font-family: var(--kb-font-serif);
    font-weight: 500;
    font-size: 22px;
    letter-spacing: -0.01em;
    margin: 24px 0 12px;
    scroll-margin-top: 80px;
  }

  .ca-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ca-list li {
    padding: 10px 0;
    border-bottom: 1px solid var(--sl-color-gray-6);
    font-size: 15px;
    line-height: 1.55;
  }

  .ca-list li:last-child {
    border-bottom: none;
  }

  .ca-summary {
    color: var(--sl-color-gray-2);
  }
</style>
